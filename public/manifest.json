{
  "manifest_version": 3,
  "name": "StageSeat",
  "version": "0.2.0",
  "minimum_chrome_version": "116",
  "description": "Use seat position to reshape live-like listening on the current tab.",
  "permissions": ["activeTab", "tabs", "storage", "offscreen", "tabCapture", "sidePanel"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Arm current tab for StageSeat"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
